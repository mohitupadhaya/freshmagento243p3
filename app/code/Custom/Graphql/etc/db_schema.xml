<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="employee_data" resource="default" engine="innodb" comment="Employee Data">
        
        <column xsi:type="int"
                name="employee_id"
                unsigned="true"
                nullable="false"
                identity="true"
                comment="Employee ID"/>

        <column xsi:type="varchar"
                name="first_name"
                nullable="false"
                length="255"
                comment="First Name"/>

        <column xsi:type="varchar"
                name="last_name"
                nullable="false"
                length="255"
                comment="Last Name"/>

        <column xsi:type="varchar"
                name="email"
                nullable="false"
                length="255"
                comment="Email Address"/>

        <column xsi:type="varchar"
                name="phone_number"
                nullable="true"
                length="20"
                comment="Phone Number"/>

        <column xsi:type="varchar"
                name="department"
                nullable="true"
                length="255"
                comment="Department"/>

        <column xsi:type="varchar"
                name="designation"
                nullable="true"
                length="255"
                comment="Designation"/>

        <column xsi:type="varchar"
                name="photo"
                nullable="true"
                length="255"
                comment="Profile Photo Path"/>

        <column xsi:type="varchar"
                name="state"
                nullable="true"
                length="100"
                comment="State"/>

        <column xsi:type="varchar"
                name="city"
                nullable="true"
                length="100"
                comment="City"/>

        <column xsi:type="varchar"
                name="distt"
                nullable="true"
                length="100"
                comment="District"/>

        <column xsi:type="varchar"
                name="pincode"
                nullable="true"
                length="10"
                comment="Pincode"/>

        <column xsi:type="smallint"
                name="status"
                nullable="false"
                default="1"
                comment="Status (1 = Active, 0 = Inactive)"/>

        <column xsi:type="timestamp"
                name="created_at"
                nullable="false"
                default="CURRENT_TIMESTAMP"
                on_update="false"
                comment="Created At"/>

        <column xsi:type="timestamp"
                name="updated_at"
                nullable="false"
                default="CURRENT_TIMESTAMP"
                on_update="true"
                comment="Updated At"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="employee_id"/>
        </constraint>

        <constraint xsi:type="unique" referenceId="EMPLOYEE_EMAIL_UNIQUE">
            <column name="email"/>
        </constraint>

    </table>
</schema>
