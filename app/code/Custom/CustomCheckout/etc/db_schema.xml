<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <!-- quote_address: store delivery_date, delivery_time, shipping_instruction -->
    <table name="quote_address" resource="default">
        <column xsi:type="date"    name="delivery_date"        nullable="true" comment="Delivery Date"/>
        <column xsi:type="varchar" name="delivery_time"        nullable="true" length="50"  comment="Delivery Time Slot"/>
        <column xsi:type="varchar" name="shipping_instruction" nullable="true" length="500" comment="Shipping Instruction"/>
    </table>

    <!-- sales_order_address: store delivery_date, delivery_time -->
    <table name="sales_order_address" resource="default">
        <column xsi:type="date"    name="delivery_date"        nullable="true" comment="Delivery Date"/>
        <column xsi:type="varchar" name="delivery_time"        nullable="true" length="50"  comment="Delivery Time Slot"/>
        <column xsi:type="varchar" name="shipping_instruction" nullable="true" length="500" comment="Shipping Instruction"/>
    </table>

    <!-- sales_order: store shipping_instruction directly on the order -->
    <table name="sales_order" resource="default">
        <column xsi:type="date"    name="delivery_date"        nullable="true" comment="Delivery Date"/>
        <column xsi:type="varchar" name="delivery_time"        nullable="true" length="50"  comment="Delivery Time Slot"/>
        <column xsi:type="varchar" name="shipping_instruction" nullable="true" length="500" comment="Shipping Instruction"/>
    </table>

</schema>