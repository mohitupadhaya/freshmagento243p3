<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Inject fields into checkout JS layout -->
    <type name="Magento\Checkout\Block\Checkout\LayoutProcessor">
        <plugin name="vendor_custom_checkout_layout"
                type="Custom\CustomCheckout\Plugin\Checkout\LayoutProcessorPlugin"
                sortOrder="10"/>
    </type>

    <!-- Save field values when shipping step is submitted -->
    <type name="Magento\Checkout\Model\ShippingInformationManagement">
        <plugin name="vendor_save_shipping_fields"
                type="Custom\CustomCheckout\Plugin\Checkout\SaveShippingFieldsPlugin"
                sortOrder="10"/>
    </type>

</config>